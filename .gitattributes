# Ensure consistent line endings across platforms
* text=auto

# Force LF for files that run inside Linux containers
*.sh text eol=lf
*.py text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf

# Houdini unpacked HDA sections — must stay LF for hotl to repack correctly
hda/**/* text eol=lf
