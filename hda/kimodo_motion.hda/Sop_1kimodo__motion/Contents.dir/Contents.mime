Content-Disposition: attachment; filename="hdaroot/apose_sop.parm"
Content-Type: text/plain

{
version 0.8
python	[ 0	locks=0 ]	(	"import os, base64, tempfile, hou
node = hou.pwd()
name = \"apose.bgeo.sc\"
raw = node.parent().type().definition().sections()[name].contents()
data = base64.b64decode(raw)
fd, path = tempfile.mkstemp(prefix=\"kimodo_\", suffix=\"_\" + name)
os.close(fd)
try:
    with open(path, \"wb\") as fh:
        fh.write(data)
    node.geometry().loadFromFile(path)
finally:
    try:
        os.remove(path)
    except OSError:
        pass
"	)
maintainstate	[ 0	locks=0 ]	(	"off"	)
}

